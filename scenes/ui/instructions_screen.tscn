[node name="InstructionsScreen" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
theme = ExtResource("2_theme")
script = ExtResource("1_info_stub")
title_text = "Instructions"
body_text = "A turn = 2 actions. If you have the ball: first you pass/shoot it in a straight line (horizontal, vertical, or diagonal) through your players, and the last player in the chain MUST shoot into an empty cell. Then you move one of your pieces 1 cell.

A goal only counts from the opponent's half. Offside: if every opposing outfield player is strictly behind you when you shoot, the goal doesn't count.

You can hold the ball among your players as long as you like. But: if a new shot lands too close to where your last clean shot landed, you get a yellow card; a second time, red; a third time, you must remove one of your players from the pitch."

